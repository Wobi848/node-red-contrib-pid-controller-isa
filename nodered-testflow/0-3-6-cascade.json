        "id": "casc036_header",
        "type": "comment",
        "z": "casc036_flow",
        "name": "=== CASCADE CONTROL TEST (PID v0.3.6) ===",
        "info": "Demonstrates cascade control with tracking mode.\n\nOuter PID (Room Temp) → Inner PID (Flow Temp) → Valve\n\nTracking prevents integrator windup when inner loop saturates.",
        "x": 280,
        "y": 40,
        "wires": []
    },
    {
        "id": "casc036_info",
        "type": "comment",
        "z": "casc036_flow",
        "name": "Room Temp (slow) → Flow Temp SP → Flow Temp (fast) → Valve | Inner output tracks back to Outer",
        "x": 360,
        "y": 80,
        "wires": []
    },
    {
        "id": "casc036_start",
