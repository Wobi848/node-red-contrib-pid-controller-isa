    {
        "id": "casc036_outer_to_inner",
        "type": "function",
        "z": "casc036_flow",
        "name": "Outer Output → Inner SP",
        "func": "// Outer PID output becomes Inner PID setpoint\nvar flowSP = msg.payload;  // Outer output = Flow setpoint\nvar flowPV = flow.get('flowTemp') || 30;\n\nflow.set('flowSP', flowSP);\n\nmsg.setpoint = flowSP;  // Inner PID setpoint\nmsg.payload = flowPV;   // Inner PID process value\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 990,
        "y": 140,
        "wires": [
