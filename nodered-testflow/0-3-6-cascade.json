        "Kp": "20",
        "Ti": "120",
        "Td": "0",
        "outMin": "30",
        "outMax": "70",
        "rateLimit": "0",
        "reverseActing": false,
        "centeredBand": false,
        "manualMode": false,
        "manualValue": "0",
        "decimals": "1",
        "maxInterval": "5",
        "ffEnable": false,
        "ffGain": "1",
        "x": 720,
