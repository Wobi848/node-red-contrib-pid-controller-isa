    {
        "id": "casc036_process",
        "type": "function",
        "z": "casc036_flow",
        "name": "Thermal Process (Room + Flow)",
        "func": "// === CASCADE THERMAL SIMULATION ===\n// Room temp responds slowly to flow temp\n// Flow temp responds quickly to valve\n\nvar roomTemp = flow.get('roomTemp') || 18;\nvar flowTemp = flow.get('flowTemp') || 30;\nvar valveOutput = flow.get('valve') || 0;\nvar flowSP = flow.get('flowSP') || 40;\nvar outsideTemp = flow.get('outside') || 5;\n\n// Flow temp: fast response to valve\nvar flowHeatGain = valveOutput * 0.8;  // Valve heats flow\nvar flowHeatLoss = (flowTemp - 20) * 0.3;  // Loss to ambient\nflowTemp = flowTemp + flowHeatGain - flowHeatLoss;\nflowTemp = Math.max(20, Math.min(80, flowTemp));  // Physical limits\n\n// Room temp: slow response to flow temp + outside influence\nvar roomHeatGain = (flowTemp - roomTemp) * 0.02;  // Radiator heats room\nvar roomHeatLoss = (roomTemp - outsideTemp) * 0.015;  // Loss to outside\nroomTemp = roomTemp + roomHeatGain - roomHeatLoss;\n\n// Add noise\nroomTemp += (Math.random() - 0.5) * 0.1;\nflowTemp += (Math.random() - 0.5) * 0.2;\n\nflow.set('roomTemp', roomTemp);\nflow.set('flowTemp', flowTemp);\n\nmsg.payload = Math.round(roomTemp * 10) / 10;  // PV for Outer PID\nmsg.roomTemp = msg.payload;\nmsg.flowTemp = Math.round(flowTemp * 10) / 10;\nmsg.flowSP = flowSP;\nmsg.valve = valveOutput;\n\n// TRACKING: Send inner loop output back to outer loop\nvar innerOutput = flow.get('innerOutput');\nif (innerOutput !== undefined) {\n    msg.trackingValue = innerOutput;  // Prevents outer integrator windup!\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 140,
        "wires": [
            [
                "casc036_outer_pid",
                "casc036_room_debug"
            ]
        ]
    },
