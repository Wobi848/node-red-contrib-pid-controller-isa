    {
        "id": "casc036_dash_fn",
        "type": "function",
        "z": "casc036_flow",
        "name": "Cascade Dashboard",
        "func": "var roomTemp = flow.get('roomTemp') || 18;\nvar flowTemp = flow.get('flowTemp') || 30;\nvar flowSP = flow.get('flowSP') || 40;\nvar valve = flow.get('valve') || 0;\nvar outside = flow.get('outside') || 5;\nvar innerOut = flow.get('innerOutput') || 0;\n\nmsg.payload = {\n    roomTemp: Math.round(roomTemp * 10) / 10,\n    flowTemp: Math.round(flowTemp * 10) / 10,\n    flowSP: Math.round(flowSP * 10) / 10,\n    valve: Math.round(valve * 10) / 10,\n    outside: outside,\n    tracking: Math.round(innerOut * 10) / 10\n};\n\nnode.status({\n    fill: 'green',\n    shape: 'dot',\n    text: 'Room:' + msg.payload.roomTemp + ' Flow:' + msg.payload.flowTemp + \n          '/' + msg.payload.flowSP + ' Valve:' + msg.payload.valve + '%'\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
